# ── local_agent.py 用の設定 ──────────────────────────────────────
# このファイルを .env.local にコピーして実際の値を設定してください

# Discord Bot Token（VPSの .env と同じもの）
DISCORD_BOT_TOKEN=your-bot-token-here

# 自分専用の Discord チャンネル ID（スノーフレーク整数）
AGENT_CHANNEL_ID=123456789012345678

# そのチャンネルの Webhook URL
# Discord チャンネル設定 → 連携サービス → ウェブフック → 新しいウェブフック
AGENT_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# claude が作業するローカルディレクトリ（省略時: ホームディレクトリ）
AGENT_WORK_DIR=/Users/yourname/your-project

# claude に許可するツール（カンマ区切り）
# AGENT_CLAUDE_TOOLS=Read,Write,Edit,Bash,Glob,Grep,LS

# claude の最大ターン数（省略時: 10）
# AGENT_MAX_TURNS=10

# Webhook に表示される Bot 名（省略時: Claude Agent）
# AGENT_BOT_NAME=Claude Agent
