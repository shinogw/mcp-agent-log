# Discord Bot Token（Developer Portal から取得）
DISCORD_BOT_TOKEN=your-bot-token-here

# 記録・通知を行うチャンネルのID（1つのチャンネルでOK、例: #cc-agent）
# チャンネルIDの確認: 開発者モードON → チャンネルを右クリック → IDをコピー
DISCORD_LOG_CHANNEL_ID=your-channel-id-here

# 同じチャンネルの Webhook URL（エージェントからの通知投稿用）
# チャンネル設定 → 連携サービス → ウェブフック → 新しいウェブフック → URLをコピー
DISCORD_NOTIFY_WEBHOOK_URL=your-webhook-url-here
